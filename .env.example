PORT=3000
API_BEARER_TOKEN=

# mariadb | sqlite (sqlite só para testes locais)
DB_DRIVER=mariadb
DB_HOST=76.13.66.204
DB_PORT=5566
DB_USER=mariadb
DB_PASSWORD=
DB_NAME=default

# Produção: use migrations (padrão). synchronize só para prototipagem local.
DB_SYNCHRONIZE=false
DB_MIGRATE=true
DB_LOGGING=false

# Usado apenas quando DB_DRIVER=sqlite
DATABASE_PATH=data/livre-tracker.sqlite

# ---------------------------------------------------------------------------
# Google Geolocation API — POST /v1/geolocate (rastreador ESP32: WiFi + torres)
# ---------------------------------------------------------------------------
# NÃO use VITE_GOOGLE_MAPS_API_KEY aqui. A chave do Maps é para o navegador (referrer HTTP).
# O servidor chama a Google sem referrer → precisa de OUTRA chave.
#
# Passo a passo (Google Cloud Console):
#   1. APIs e serviços → Biblioteca → ativar "Geolocation API"
#   2. Credenciais → Criar credencial → Chave de API
#   3. Editar a chave → Restrições de aplicativo → "Endereços IP"
#      Adicionar IP do servidor da API (ex.: 76.13.66.204 para api.livretracker.com)
#   4. Restrições de API → marcar só "Geolocation API"
#   5. Colar a chave abaixo e reiniciar a API (Coolify / docker)
#   6. Testar: bash scripts/test-geolocate.sh https://api.livretracker.com
#   7. No ESP32: config.h → HYBRID_GEOLOCATION_ENABLED 1 e regravar firmware
#
GOOGLE_GEOLOCATION_API_KEY=

# SMS (Comtele)
# COMTELE_URL=https://sms.comtele.com.br
# COMTELE_AUTH_KEY=
# COMTELE_AUTH_KEY_MKT=
# COMTELE_SENDER_ID=66912
